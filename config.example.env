# PIITool local vault
PIITOOL_VAULT_PATH=./piitool.sqlite

# Optional. If set, attribute values in the SQLite vault are encrypted with AES-GCM.
# Use a long random value and keep it outside git.
PIITOOL_VAULT_KEY=

# Detection mode: regex | local_llm | hybrid
PIITOOL_DETECTOR_MODE=hybrid

# Local structured-output detector
OLLAMA_BASE_URL=http://localhost:11434
PIITOOL_DETECTOR_MODEL=qwen2.5:7b
# Keep Ollama model loaded after requests. Examples: 10m, 1h, -1.
PIITOOL_OLLAMA_KEEP_ALIVE=10m

# OpenAI-compatible upstream used by /v1/chat/completions and audio STT fallback
PIITOOL_UPSTREAM_BASE_URL=https://api.openai.com
PIITOOL_UPSTREAM_API_KEY=
PIITOOL_UPSTREAM_MODEL=

# Gateway
PIITOOL_GATEWAY_PORT=4317
PIITOOL_FAIL_CLOSED=0
# Password for web UI. If unset, UI is accessible without auth.
PIITOOL_GATEWAY_PASSWORD=
# Session TTL in milliseconds (default 1h)
PIITOOL_SESSION_TTL_MS=3600000

# Review mode: auto | queue
# auto keeps current behavior and records fuzzy review hints.
# queue creates pending review items for unknown/fuzzy people and companies while still anonymizing.
PIITOOL_REVIEW_MODE=auto

# Image/audio adapters
PIITOOL_VISION_MODEL=llava
PIITOOL_STT_BASE_URL=
PIITOOL_STT_API_KEY=
PIITOOL_STT_MODEL=whisper-1

# MCP stdio proxy.
# Example:
# PIITOOL_MCP_COMMAND=npx -y @modelcontextprotocol/server-filesystem /Users/red
PIITOOL_MCP_COMMAND=

# SecurityAgent: off | policy | agent | agent_with_human
# policy uses stored allow/deny rules only.
# agent asks the local LLM when no policy matches.
# agent_with_human turns agent checks into gateway pending approvals.
PIITOOL_SECURITY_MODE=policy
PIITOOL_SECURITY_MODEL=qwen2.5:7b
PIITOOL_SECURITY_TIMEOUT_MS=600000
PIITOOL_SECURITY_DEFAULT=pending_approval
PIITOOL_SECURITY_TOKEN=

# LegislatorAgent: user-only ruleset editor for SecurityAgent.
PIITOOL_LEGISLATOR_MODEL=qwen2.5:7b
PIITOOL_LEGISLATOR_MAX_HISTORY=50
